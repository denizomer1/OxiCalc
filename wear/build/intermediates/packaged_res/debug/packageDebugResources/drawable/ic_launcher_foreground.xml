<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Deep Base Shadow / Depth -->
    <path
        android:pathData="M54,18 C54,18 28,48 28,72 A26,26 0 1,0 80,72 C80,48 54,18 54,18 Z"
        android:fillColor="#3D85FF"/>

    <!-- Main Liquid Body with Gradient -->
    <path android:pathData="M54,18 C54,18 28,48 28,72 A26,26 0 1,0 80,72 C80,48 54,18 54,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="18"
                android:endX="54"
                android:endY="98"
                android:type="linear">
                <item android:offset="0" android:color="#FF6EB4FF"/>
                <item android:offset="1" android:color="#FF3D85FF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glass Highlight (Top Shine) -->
    <path android:pathData="M54,22 C48,22 34,42 34,55 C34,58 38,52 54,52 C70,52 74,58 74,55 C74,42 60,22 54,22 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="22"
                android:endX="54"
                android:endY="52"
                android:type="linear">
                <item android:offset="0" android:color="#80FFFFFF"/>
                <item android:offset="1" android:color="#00FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom Inner Glow (Refraction) -->
    <path android:pathData="M40,85 A14,14 0 0,0 68,85 A14,14 0 0,0 40,85 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="98"
                android:endX="54"
                android:endY="75"
                android:type="linear">
                <item android:offset="0" android:color="#40FFFFFF"/>
                <item android:offset="1" android:color="#00FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Architectural Minimalist Symbols -->
    <!-- Plus (+) -->
    <group
        android:translateX="42"
        android:translateY="56">
        <path
            android:pathData="M5,0 h2 v12 h-2 z M0,5 h12 v2 h-12 z"
            android:fillColor="#FFFFFF"/>
    </group>

    <!-- Minus (-) -->
    <group
        android:translateX="58"
        android:translateY="61">
        <path
            android:pathData="M0,0 h10 v2 h-10 z"
            android:fillColor="#FFFFFF"/>
    </group>

    <!-- Multiplication (X) -->
    <group
        android:translateX="50"
        android:translateY="75">
        <path
            android:pathData="M1.5,0.08 l3.5,3.5 l3.5,-3.5 l1.42,1.42 l-3.5,3.5 l3.5,3.5 l-1.42,1.42 l-3.5,-3.5 l-3.5,3.5 l-1.42,-1.42 l3.5,-3.5 l-3.5,-3.5 z"
            android:fillColor="#FFFFFF"/>
    </group>

</vector>